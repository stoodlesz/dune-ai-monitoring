# ---------------------------
# Python
# ---------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.env/
.envrc/

# Python build
build/
dist/
*.egg-info/

# ---------------------------
# Jupyter
# ---------------------------
.ipynb_checkpoints/

